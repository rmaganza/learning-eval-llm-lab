# Eval Lab environment variables
# Copy to .env and fill in values: cp .env.example .env

# API keys (required for inference)
OPENAI_API_KEY=sk-...

# For Anthropic or other providers: set BOTH base URL and key together
# EVAL_API_BASE_URL=https://api.anthropic.com/v1/
# EVAL_API_KEY=sk-ant-...

# Storage (optional; defaults to SQLite)
# DATABASE_URL=sqlite+aiosqlite:///eval_runs.sqlite
# DATABASE_URL=postgresql://user:pass@localhost:5432/eval_lab

# Persistence (optional; default: true)
# EVAL_LAB_PERSIST=true

# Concurrency and limits (optional)
# EVAL_CONCURRENCY=4
# EVAL_MAX_EXAMPLES=100
